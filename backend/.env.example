# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tfp_db

# Redis / BullMQ
REDIS_URL=redis://localhost:6379
BULLMQ_PREFIX=tfp

# Payroll defaults for async recalculation jobs
PAYROLL_DEFAULT_BASE_SALARY=0
PAYROLL_DEFAULT_TASK_BONUS_RATE=0

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
# Comma-separated allowlist (no spaces required)
# Example:
# CORS_ORIGIN=http://localhost:5173,https://vantatfp.netlify.app
CORS_ORIGIN=http://localhost:5173
