# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tfp_db
DB_URL=postgresql://user:password@localhost:5432/tfp_db
BACKUP_PATH=backups

# Redis / BullMQ (required; no in-app default — set explicitly, e.g. Railway Redis plugin REDIS_URL)
REDIS_URL=
BULLMQ_PREFIX=tfp

# Payroll defaults for async recalculation jobs
PAYROLL_DEFAULT_BASE_SALARY=0
PAYROLL_DEFAULT_TASK_BONUS_RATE=0

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
# Comma-separated allowlist (no spaces required). Include every dev origin you use
# (localhost vs 127.0.0.1 are different origins).
# Example:
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://vantatfp.netlify.app
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
