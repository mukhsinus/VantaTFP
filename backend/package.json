{
  "name": "tfp-backend",
  "version": "1.0.0",
  "description": "TFP SaaS Backend — Modular Monolith with Fastify + TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "tsx src/worker.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:up": "tsx src/tools/migrate.ts up",
    "migrate:down": "tsx src/tools/migrate.ts down",
    "migrate:status": "tsx src/tools/migrate.ts status",
    "migrate:validate": "tsx src/tools/validate-migrations.ts",
    "migrate:source:check": "tsx src/tools/enforce-migration-source.ts",
    "schema:contract": "tsx src/tools/validate-schema-contract.ts",
    "backup": "tsx scripts/backup.ts",
    "restore": "tsx scripts/restore.ts",
    "create-super-admin": "tsx scripts/createSuperAdmin.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/websocket": "^11.2.0",
    "@sentry/node": "^10.47.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.2",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.10.1",
    "pg": "^8.14.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.13",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
